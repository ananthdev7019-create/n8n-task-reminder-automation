    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const today = new Date();\ntoday.setHours(0,0,0,0);\n\nconst dueDateStr = $json[\"Due Date\"];\nconst status = $json[\"Status\"];\n\n// Skip if no date or already completed\nif (!dueDateStr || status === \"Completed\") {\n  return { json: { ...$json, SendEmail: false } };\n}\n\nconst [day, month, year] = dueDateStr.split('/');\nconst dueDate = new Date(`${year}-${month}-${day}`);\ndueDate.setHours(0,0,0,0);\n\nif (dueDate.getTime() === today.getTime()) {\n\n  $json.Status = \"Completed\";\n  $json.SendEmail = true;\n\n} else {\n\n  $json.SendEmail = false;\n\n}\n\nreturn { json: $json };"
      },
