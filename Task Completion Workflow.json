    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const today = new Date();\ntoday.setHours(0,0,0,0);\n\nconst dueDateStr = $json[\"Due Date\"];\nconst currentStatus = $json[\"Status\"];\n\n// STOP if task already completed\nif (currentStatus === \"Completed\") {\n  $json.SendReminder = false;\n  return { json: $json };\n}\n\nlet sendReminder = false;\nlet reminderType = null;\nlet newStatus = currentStatus || \"Pending\";\n\nif (dueDateStr) {\n\n  const [day, month, year] = dueDateStr.split('/');\n  const dueDate = new Date(`${year}-${month}-${day}`);\n  dueDate.setHours(0,0,0,0);\n\n  const diffTime = dueDate.getTime() - today.getTime();\n  const daysRemaining = Math.ceil(diffTime / (1000 * 60 * 60 * 24));\n\n  const lastReminder = $json[\"LastReminderSent\"];\n\n  // Prevent duplicate reminder today\n  if (lastReminder) {\n\n    const [d, m, y] = lastReminder.split('/');\n    const lastDate = new Date(`${y}-${m}-${d}`);\n    lastDate.setHours(0,0,0,0);\n\n    if (lastDate.getTime() !== today.getTime()) {\n\n      if (daysRemaining === 3 && newStatus === \"Pending\") {\n        reminderType = \"Reminder - 3 days left\";\n        newStatus = \"Reminder Sent (3 days)\";\n        sendReminder = true;\n      }\n\n      else if (daysRemaining === 1 && newStatus !== \"Final Reminder Sent\") {\n        reminderType = \"Reminder - 1 day left\";\n        newStatus = \"Reminder Sent (1 day)\";\n        sendReminder = true;\n      }\n\n      else if (daysRemaining === 0) {\n        reminderType = \"Final Reminder - Due Today\";\n        newStatus = \"Final Reminder Sent\";\n        sendReminder = true;\n      }\n    }\n\n  } else {\n\n    if (daysRemaining === 3 || daysRemaining === 1 || daysRemaining === 0) {\n      sendReminder = true;\n      reminderType = \"Task Reminder\";\n    }\n\n  }\n\n  if (sendReminder) {\n\n    const dd = String(today.getDate()).padStart(2,'0');\n    const mm = String(today.getMonth()+1).padStart(2,'0');\n    const yyyy = today.getFullYear();\n\n    $json.ReminderType = reminderType;\n    $json.DaysRemaining = daysRemaining;\n    $json.Status = newStatus;\n    $json.LastReminderSent = `${dd}/${mm}/${yyyy}`;\n\n  }\n\n}\n\n$json.SendReminder = sendReminder;\n\nreturn { json: $json };"
      },
